# UniOS Package Repository
# Installable via: apt update && apt install <name>
#
# Format: @<name> <version> <description>
#         depends: <dep1> <dep2> ...
#         files: <path1> <path2> ...
# File paths are relative to this repo directory.
# apt downloads from <source_url>/<path> and installs to /<path>.

@gui 1.0.0 Graphical desktop environment with compositor, taskbar, file browser, and terminal
depends:
files: lib/libgui.lua bin/compositor.lua
