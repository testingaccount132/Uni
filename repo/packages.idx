# UniOS Package Repository
# Installable via: apt update && apt install <name>
#
# Format: @<name> <version> <description>
#         depends: <dep1> <dep2> ...
#         files: <path1> <path2> ...
# File paths are relative to this repo directory.
# apt downloads from <source_url>/<path> and installs to /<path>.

@gui 1.0.0 Graphical desktop environment with compositor, taskbar, file browser, and terminal
depends:
files: lib/libgui.lua bin/compositor.lua

@bash 1.0.0 Advanced shell with functions, arrays, arithmetic, test/[, and more
depends:
files: bin/bash.lua

@nano 1.1.0 Terminal text editor with search, syntax highlighting, and line numbers
depends:
files: bin/nano.lua

@dev-tools 1.0.0 Development utilities (get, uninstall)
depends:
files: tools/get.lua tools/uninstall.lua
